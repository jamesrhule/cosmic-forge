{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qcompass:statmech/manifest",
  "title": "Stat Mech · Sampling manifest",
  "type": "object",
  "required": [
    "method",
    "beta"
  ],
  "properties": {
    "method": {
      "type": "string",
      "default": "qae",
      "enum": [
        "qae",
        "quantum-metropolis",
        "tfd"
      ]
    },
    "beta": {
      "type": "number",
      "default": 1
    },
    "precision_bits": {
      "type": "integer",
      "default": 6
    }
  }
}