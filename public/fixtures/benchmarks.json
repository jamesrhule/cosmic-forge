{
  "benchmarks": [
    {
      "id": "bench-kawai-kim",
      "label": "Kawai-Kim 2017 (natural inflation)",
      "arxivId": "1702.07689",
      "description": "V2 baseline used for \u03b7_B recovery checks.",
      "config": {
        "potential": {
          "kind": "natural",
          "params": {
            "f": 7e16,
            "Lambda4": 2.5e-7
          }
        },
        "couplings": {
          "xi": 0.0085,
          "theta_grav": 0.78,
          "f_a": 1e16,
          "M_star": 2.4e18,
          "M1": 10000000000.0,
          "S_E2": 0.046
        },
        "reheating": {
          "Gamma_phi": 100000000.0,
          "T_reh_GeV": 1500000000.0
        },
        "precision": "standard"
      },
      "expectedEta_B": 6.1e-10
    },
    {
