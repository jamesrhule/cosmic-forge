{
  "name": "@qcompass/frontend-sdk",
  "version": "0.1.0",
  "description": "QCompass frontend SDK — typed clients for the qcompass HTTP / WS surface (PROMPT 8 v2).",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./services": {
      "types": "./src/services.ts",
      "import": "./src/services.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "scripts": {
    "regen-types": "datamodel-codegen --input ../../qcompass-core/src/qcompass_core --input-file-type pydantic --output ./src/types.ts --target-python-version 3.12 --output-model-type typing.TypedDict"
  },
  "engines": {
    "node": ">=18"
  }
}
